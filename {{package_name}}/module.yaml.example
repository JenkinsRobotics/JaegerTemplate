# module.yaml — the manifest JaegerOS's discover_modules() reads to bind
# this module into the slot system. Copy this to module.yaml (drop the
# .example suffix) and fill in every field before this module is
# discoverable. One copy of every truth: nothing else in this repo should
# restate what's declared here (see CONVENTIONS.md, law 1).
#
# Modelled on jaeger_os/nodes/kokoro_tts/module.yaml in JaegerOS — read
# that file alongside this one if anything below is unclear.

# The module's own name — must match the directory name under wherever
# this module gets discovered from (jaeger_os/nodes/<name>/ or
# jaeger_os/plugins/<name>/ in-tree; an out-of-tree module root once 0.9's
# out-of-tree loading lands).
module: "{{package_name}}"

# The slot this module fills. Most slots are one-module (tts, stt,
# vision, ...); a few are genuinely multi-module (messaging — discord/
# telegram/imessage coexist, ANY-OF readiness). Pick the slot name your
# project's slot registry expects, or invent a new one if this is the
# first module to fill it.
slot: "{{slot_name}}"

# Semver. Bump on any change to this file's consumes/produces/tools
# contract (CONVENTIONS.md "Versioning & pinning") — patch/minor for
# additive, non-breaking; major for a breaking wire-format or topic
# rename that needs coordinated updates on the consuming side.
version: 0.1.0

# Bus topics this module SUBSCRIBES to (the commands it acts on).
# Empty list if this module only produces (e.g. a pure sensor).
consumes: []
# consumes: [/act/{{package_name}}]

# Bus topics this module PUBLISHES (the results/acks it produces).
produces: []
# produces: [/sense/{{package_name}}_result]

# Tool names this module makes available to the agent's tool registry
# (the tool ↔ node contract: "a tool does the networking, the node does
# the execution" — the agent's tool call becomes a bus publish + a
# correlation-ID wait for the ack on one of the `produces` topics above).
tools: []
# tools: [do_the_thing]

# Dotted path to the factory function module discovery calls to build a
# live node on an injected bus: `factory(bus, config) -> Node`. Must be
# importable from this module's __init__.py (or the file it points at).
factory: "{{package_name}}:make_{{package_name}}_node"

# This module's group/key in the settings catalog — must match the
# Pydantic model exported from config.py (see config.py.example). Leave
# blank (or delete this line) if the module ships no configurable
# settings.
config: "{{package_name}}"

# The third-party libraries this module's engine actually imports at
# runtime. The availability gate probes these with
# importlib.util.find_spec BEFORE reporting this module's tools
# available — so a missing optional dependency degrades to "tool
# unavailable" instead of a crash at agent boot.
requires_libraries: []
# requires_libraries: [some_pip_package]

# Restrict this module to specific platforms when it shells out to a
# platform-only API (e.g. AppleScript, CoreAudio). Omit entirely for
# platform-agnostic modules. Valid values mirror sys.platform: darwin,
# linux, win32.
# requires_platform: [darwin]
